# Formspree form ID (from https://formspree.io/f/xxxxx — use the xxxxx part)
# Set in Vercel → Settings → Environment Variables, then redeploy.
FORMSPREE_FORM_ID=
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# Optional: override for sitemap/OG URLs when using a custom domain
NEXT_PUBLIC_SITE_URL=https://studio-baroque.vercel.app
